DJANGO_ENV=prod
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=0
APP_URL=https://expenses.example.com
ALLOWED_HOSTS=expenses.example.com
CSRF_TRUSTED_ORIGINS=https://expenses.example.com

POSTGRES_DB=waexp
POSTGRES_USER=waexp
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

WA_VERIFY_TOKEN=replace-me
WA_TEMPORARY_TOKEN=replace-me

AZURE_ACCOUNT_NAME=replace-me
AZURE_ACCOUNT_KEY=replace-me
AZURE_CONTAINER=waexp-media
AZURE_URL_EXPIRATION_SECS=3600
AZURE_CUSTOM_DOMAIN=
AZURE_CONNECTION_STRING=

RUN_MIGRATIONS=1
COLLECTSTATIC=1
WAIT_FOR_DB=1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

